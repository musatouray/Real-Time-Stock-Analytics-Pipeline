# Normalize line endings to LF in the repo; checkout as-is on all platforms
* text=auto eol=lf

# Force LF for shell scripts and Python files
*.sh    text eol=lf
*.py    text eol=lf
*.sql   text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf
*.md    text eol=lf
*.txt   text eol=lf
*.csv   text eol=lf
*.env*  text eol=lf

# Binary files — no line-ending conversion
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.ico   binary
*.pdf   binary
