# ─────────────────────────────────────────────────────────────
# FINNHUB
# ─────────────────────────────────────────────────────────────
FINNHUB_API_KEY=your_finnhub_api_key_here
FINNHUB_WS_URL=wss://ws.finnhub.io

# ─────────────────────────────────────────────────────────────
# KAFKA
# ─────────────────────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_TOPIC_TRADES=stock.trades
KAFKA_TOPIC_QUOTES=stock.quotes
KAFKA_CONSUMER_GROUP=stock-s3-consumer
KAFKA_AUTO_OFFSET_RESET=earliest

# ─────────────────────────────────────────────────────────────
# AWS
# ─────────────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
AWS_REGION=us-east-1
S3_BUCKET_NAME=your-stock-analytics-bucket
S3_RAW_PREFIX=raw/trades/
S3_BATCH_SIZE=100
S3_FLUSH_INTERVAL_SECONDS=60

# ─────────────────────────────────────────────────────────────
# SNOWFLAKE
# ─────────────────────────────────────────────────────────────
SNOWFLAKE_ACCOUNT=your_account.snowflakecomputing.com
SNOWFLAKE_USER=your_snowflake_user
SNOWFLAKE_PASSWORD=your_snowflake_password
SNOWFLAKE_ROLE=STOCK_ANALYTICS_ROLE
SNOWFLAKE_WAREHOUSE=STOCK_ANALYTICS_WH
SNOWFLAKE_DATABASE=STOCK_ANALYTICS_DB
SNOWFLAKE_SCHEMA=RAW

# ─────────────────────────────────────────────────────────────
# DBT
# ─────────────────────────────────────────────────────────────
DBT_PROFILES_DIR=/usr/app/dbt
DBT_PROJECT_DIR=/usr/app/dbt
DBT_TARGET=prod

# ─────────────────────────────────────────────────────────────
# AIRFLOW
# ─────────────────────────────────────────────────────────────
AIRFLOW_UID=50000
AIRFLOW__CORE__EXECUTOR=CeleryExecutor
AIRFLOW__CORE__FERNET_KEY=your_fernet_key_here
AIRFLOW__CORE__DAGS_ARE_PAUSED_AT_CREATION=true
AIRFLOW__CORE__LOAD_EXAMPLES=false
AIRFLOW__WEBSERVER__SECRET_KEY=your_webserver_secret_key
AIRFLOW__DATABASE__SQL_ALCHEMY_CONN=postgresql+psycopg2://airflow:airflow@postgres/airflow
AIRFLOW__CELERY__RESULT_BACKEND=db+postgresql://airflow:airflow@postgres/airflow
AIRFLOW__CELERY__BROKER_URL=redis://:@redis:6379/0
AIRFLOW_WWW_USER_USERNAME=admin
AIRFLOW_WWW_USER_PASSWORD=admin
AIRFLOW_WWW_USER_EMAIL=admin@example.com

# ─────────────────────────────────────────────────────────────
# POSTGRES (Airflow metadata)
# ─────────────────────────────────────────────────────────────
POSTGRES_USER=airflow
POSTGRES_PASSWORD=airflow
POSTGRES_DB=airflow
