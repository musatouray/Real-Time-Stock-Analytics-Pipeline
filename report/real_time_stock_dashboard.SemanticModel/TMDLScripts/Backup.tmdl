					//     __SelectedCalItem = "5Y",
					//         FORMAT(_MinDate, "MM-dd-yyyy") & " to " & FORMAT(_MaxDate, "MM-dd-yyyy"),
					
					//     __SelectedCalItem = "YTD",
					//         FORMAT(_MinDate, "MM-dd-yyyy") & " to " & FORMAT(_MaxDate, "MM-dd-yyyy"),
					
					//     __SelectedCalItem = "All",
					//         FORMAT(_MinDate, "MM-dd-yyyy") & " to " & FORMAT(_MaxDate, "MM-dd-yyyy"),
					
					//     "No Period Selected"
					// )
				displayFolder: Dynamic Period Filter
				lineageTag: 8970ed2f-471e-408a-99dd-80731758fdd3

