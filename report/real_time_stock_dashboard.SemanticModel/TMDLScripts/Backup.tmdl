createOrReplace

	model Model
		culture: en-US
		defaultPowerBIDataSourceVersion: powerBI_V3
		discourageImplicitMeasures
		sourceQueryCulture: en-US
		dataAccessOptions
			legacyRedirects
			returnErrorValuesAsNull

		/// Company dimension table containing stock metadata. Links to fact tables via SYMBOL.
		table dim_companies
			lineageTag: 4e403a14-af18-4005-8329-7699c84369dd

			/// Stock ticker symbol (e.g., AAPL, MSFT). Primary key for joining to fact tables.
			column SYMBOL
				dataType: string
				lineageTag: 374f024b-3b65-4d67-969d-82a9d297aa79
				summarizeBy: none
				sourceColumn: SYMBOL

				annotation SummarizationSetBy = Automatic

			/// Full legal company name (e.g., Apple Inc., Microsoft Corporation).
			column COMPANY_NAME
				dataType: string
				lineageTag: 514a7314-da54-446f-8633-22f88e12d925
				summarizeBy: none
				sourceColumn: COMPANY_NAME

				annotation SummarizationSetBy = Automatic

			/// Stock exchange where the security trades (NASDAQ or NYSE).
			column EXCHANGE
				dataType: string
				lineageTag: 7c2a0cd7-c075-4ca1-988f-935fb866dd55
				summarizeBy: none
				sourceColumn: EXCHANGE

				annotation SummarizationSetBy = Automatic

			/// URL to company logo image. Used for visual display in reports.
			column LOGO_URL
				dataType: string
				lineageTag: 385768ff-1263-43d4-8c1c-3b736c629ada
				dataCategory: ImageUrl
				summarizeBy: none
				sourceColumn: LOGO_URL

				annotation SummarizationSetBy = Automatic

			column SECTOR
				dataType: string
				lineageTag: 0f5457ec-9992-45a0-9a44-a98f59cd5223
				summarizeBy: none
				sourceColumn: SECTOR

				annotation SummarizationSetBy = Automatic

			column INDUSTRY
				dataType: string
				lineageTag: bca7402d-04be-4981-a221-2c43a948b059
				summarizeBy: none
				sourceColumn: INDUSTRY

				annotation SummarizationSetBy = Automatic

			partition dim_companies = m
				mode: import
				source =
						let
						    Source = Snowflake.Databases("JDGAEPV-LHA81787.snowflakecomputing.com","STOCK_ANALYTICS_WH",[Implementation="1.0"]),
						    STOCK_ANALYTICS_DB_Database = Source{[Name="STOCK_ANALYTICS_DB",Kind="Database"]}[Data],
						    MARTS_Schema = STOCK_ANALYTICS_DB_Database{[Name="MARTS",Kind="Schema"]}[Data],
						    DIM_COMPANIES_Table = MARTS_Schema{[Name="DIM_COMPANIES",Kind="Table"]}[Data],
						    #"Removed Other Columns" = Table.SelectColumns(DIM_COMPANIES_Table,{"SYMBOL", "COMPANY_NAME", "SECTOR", "INDUSTRY", "EXCHANGE", "LOGO_URL"})
						in
						    #"Removed Other Columns"

			annotation PBI_ResultType = Table

			annotation PBI_NavigationStepName = Navigation

		/// Hourly OHLCV fact table aggregating trade data into candlestick format. Grain: one row per (symbol, hour).
		table fct_stock_ohlcv_hourly
			lineageTag: 0e3171df-aa5a-49a2-8983-c2109231007c

			/// Stock ticker symbol. Foreign key to dim_companies.
			column SYMBOL
				dataType: string
				lineageTag: 13c7c7e0-cd74-4c16-b52a-cdc70a5b8c83
				summarizeBy: none
				sourceColumn: SYMBOL

				annotation SummarizationSetBy = Automatic

			/// First trade price within the hour. Used for candlestick open.
			column OPEN_PRICE
				dataType: double
				lineageTag: 02103a5c-3136-4b55-8fa3-7a61d89c03c8
				summarizeBy: sum
				sourceColumn: OPEN_PRICE

				annotation SummarizationSetBy = Automatic

				annotation PBI_FormatHint = {"isGeneralNumber":true}

			/// Maximum trade price within the hour. Upper wick of candlestick.
			column HIGH_PRICE
				dataType: double
				lineageTag: 1809f490-f9f2-454a-944a-fbe3af2c7b14
				summarizeBy: sum
				sourceColumn: HIGH_PRICE

				annotation SummarizationSetBy = Automatic

				annotation PBI_FormatHint = {"isGeneralNumber":true}

			/// Minimum trade price within the hour. Lower wick of candlestick.
			column LOW_PRICE
				dataType: double
				lineageTag: be95c611-aee3-4b6b-8e4f-59c7f8f68d81
				summarizeBy: sum
				sourceColumn: LOW_PRICE

				annotation SummarizationSetBy = Automatic

				annotation PBI_FormatHint = {"isGeneralNumber":true}

			/// Last trade price within the hour. Used for candlestick close and VWAP comparison.
			column CLOSE_PRICE
				dataType: double
				lineageTag: f1bda740-ddb3-4f3c-92df-1a9e9c1bf2ed
				summarizeBy: sum
				sourceColumn: CLOSE_PRICE

				annotation SummarizationSetBy = Automatic

				annotation PBI_FormatHint = {"isGeneralNumber":true}

			/// Total shares traded within the hour. Key metric for volume spike analysis.
			column TOTAL_VOLUME
				dataType: double
				lineageTag: ca6dfb52-9f6f-4b95-9277-cce21ea5b5f4
				summarizeBy: sum
				sourceColumn: TOTAL_VOLUME

				annotation SummarizationSetBy = Automatic

				annotation PBI_FormatHint = {"isGeneralNumber":true}

			/// Number of individual trades within the hour. Indicates market participation level.
			column TRADE_COUNT
				dataType: double
				lineageTag: 3ed49e2a-038c-4734-b37e-028780431693
				summarizeBy: sum
				sourceColumn: TRADE_COUNT

				annotation SummarizationSetBy = Automatic

				annotation PBI_FormatHint = {"isGeneralNumber":true}

			/// Volume-Weighted Average Price. Institutional benchmark for execution quality.
			column VWAP
				dataType: double
				lineageTag: b321f0a2-c155-443c-97ea-c40d18134453
				summarizeBy: sum
				sourceColumn: VWAP

				annotation SummarizationSetBy = Automatic

				annotation PBI_FormatHint = {"isGeneralNumber":true}

			/// Standard deviation of trade prices within the hour. Primary volatility metric.
			column STDDEV_PRICE
				dataType: double
				lineageTag: 0d560c83-b8e7-4193-8f83-9d7843bea5d2
				summarizeBy: sum
				sourceColumn: STDDEV_PRICE

				annotation SummarizationSetBy = Automatic

				annotation PBI_FormatHint = {"isGeneralNumber":true}

			/// High minus Low price (intraday range). Alternative volatility measure.
			column PRICE_RANGE
				dataType: double
				lineageTag: 3a665413-425d-47af-9a58-8650019c5de3
				summarizeBy: sum
				sourceColumn: PRICE_RANGE

				annotation SummarizationSetBy = Automatic

				annotation PBI_FormatHint = {"isGeneralNumber":true}

			/// Percentage price change (close vs open). Key metric for momentum and correlation analysis.
			column PCT_CHANGE
				dataType: double
				formatString: 0.00%;-0.00%;0.00%
				lineageTag: a29bd5ef-18be-4997-8ecf-b4ed8153a0a2
				summarizeBy: average
				sourceColumn: PCT_CHANGE

				annotation SummarizationSetBy = User

			/// Calendar date of trading (US/Eastern timezone).
			column TRADED_DATE
				dataType: dateTime
				formatString: Short Date
				lineageTag: d7006fea-e1b3-48df-987e-b7d53ff9d995
				summarizeBy: none
				sourceColumn: TRADED_DATE

				annotation SummarizationSetBy = Automatic

				annotation UnderlyingDateTimeDataType = Date

			/// Hour of day (9 AM - 4 PM ET market hours). Use for intraday heatmaps.
			column TRADED_HOUR
				dataType: dateTime
				formatString: Short Time
				lineageTag: c52fd6d5-7621-4c29-a9b6-aff96a3e928d
				summarizeBy: none
				sourceColumn: TRADED_HOUR

				annotation SummarizationSetBy = Automatic

				annotation UnderlyingDateTimeDataType = Time

			/// Integer date key (YYYYMMDD format). Foreign key to dim_date.
			column DATE_KEY
				dataType: double
				lineageTag: a67c361b-f0e4-406a-874a-0da1df3c990e
				summarizeBy: none
				sourceColumn: DATE_KEY

				annotation SummarizationSetBy = Automatic

				annotation PBI_FormatHint = {"isGeneralNumber":true}

			partition fct_stock_ohlcv_hourly = m
				mode: import
				source =
						let
						    Source = Snowflake.Databases("JDGAEPV-LHA81787.snowflakecomputing.com","STOCK_ANALYTICS_WH",[Implementation="1.0"]),
						    STOCK_ANALYTICS_DB_Database = Source{[Name="STOCK_ANALYTICS_DB",Kind="Database"]}[Data],
						    MARTS_Schema = STOCK_ANALYTICS_DB_Database{[Name="MARTS",Kind="Schema"]}[Data],
						    FCT_STOCK_OHLCV_HOURLY_Table = MARTS_Schema{[Name="FCT_STOCK_OHLCV_HOURLY",Kind="Table"]}[Data],
						    #"Removed Other Columns" = Table.SelectColumns(FCT_STOCK_OHLCV_HOURLY_Table,{"SYMBOL", "TRADED_DATE", "TRADED_HOUR", "OPEN_PRICE", "HIGH_PRICE", "LOW_PRICE", "CLOSE_PRICE", "TOTAL_VOLUME", "TRADE_COUNT", "VWAP", "STDDEV_PRICE", "PRICE_RANGE", "PCT_CHANGE", "DATE_KEY"})
						in
						    #"Removed Other Columns"

			annotation PBI_ResultType = Table

			annotation PBI_NavigationStepName = Navigation

		/// Trade-level fact table containing individual stock transactions. Grain: one row per trade.
		table fct_stock_trades
			lineageTag: 8cc35b09-aa96-4155-9f04-0ba1e408c07b

			/// Stock ticker symbol. Foreign key to dim_companies.
			column SYMBOL
				dataType: string
				lineageTag: 04822078-6992-4f79-bd72-9658ef35aed9
				summarizeBy: none
				sourceColumn: SYMBOL

				annotation SummarizationSetBy = Automatic

			/// Trade execution price in USD.
			column PRICE
				dataType: double
				lineageTag: 17af1e37-5bb2-4237-8c75-9e19e33d68df
				summarizeBy: sum
				sourceColumn: PRICE

				annotation SummarizationSetBy = Automatic

				annotation PBI_FormatHint = {"isGeneralNumber":true}

			/// Number of shares in this trade.
			column VOLUME
				dataType: double
				lineageTag: 8b8a49ac-bc37-4709-9b8f-0c4bc97b4774
				summarizeBy: sum
				sourceColumn: VOLUME

				annotation SummarizationSetBy = Automatic

				annotation PBI_FormatHint = {"isGeneralNumber":true}

			/// Dollar value of trade (price x volume).
			column TRADE_VALUE_USD
				dataType: double
				lineageTag: b991007a-df5c-4e19-82a7-27f0d6291f39
				summarizeBy: sum
				sourceColumn: TRADE_VALUE_USD

				annotation SummarizationSetBy = Automatic

				annotation PBI_FormatHint = {"isGeneralNumber":true}

			/// Exact timestamp of trade execution (US/Eastern timezone).
			column TRADED_AT
				dataType: dateTime
				formatString: General Date
				lineageTag: 30fb485c-6b84-46d8-a020-ea2f5981ee14
				summarizeBy: none
				sourceColumn: TRADED_AT

				annotation SummarizationSetBy = Automatic

			/// Hour component of trade time. Use for grouping trades by market hour.
			column TRADED_HOUR
				dataType: dateTime
				formatString: Long Time
				lineageTag: a29652fc-75a5-43ec-a347-a82a8e886185
				summarizeBy: none
				sourceColumn: TRADED_HOUR

				annotation SummarizationSetBy = Automatic

				annotation UnderlyingDateTimeDataType = Time

			/// Calendar date of trade (US/Eastern timezone).
			column TRADED_DATE
				dataType: dateTime
				formatString: Long Date
				lineageTag: c7a5eec1-2be8-451d-9da1-dfeb84568351
				summarizeBy: none
				sourceColumn: TRADED_DATE

				annotation SummarizationSetBy = Automatic

				annotation UnderlyingDateTimeDataType = Date

			/// Integer date key (YYYYMMDD format). Foreign key to dim_date.
			column DATE_KEY
				dataType: double
				lineageTag: e7146304-f0e9-4d34-85e0-c7eefe79329c
				summarizeBy: none
				sourceColumn: DATE_KEY

				annotation SummarizationSetBy = Automatic

				annotation PBI_FormatHint = {"isGeneralNumber":true}

			partition fct_stock_trades = m
				mode: import
				source =
						let
						    Source = Snowflake.Databases("JDGAEPV-LHA81787.snowflakecomputing.com","STOCK_ANALYTICS_WH",[Implementation="1.0"]),
						    STOCK_ANALYTICS_DB_Database = Source{[Name="STOCK_ANALYTICS_DB",Kind="Database"]}[Data],
						    MARTS_Schema = STOCK_ANALYTICS_DB_Database{[Name="MARTS",Kind="Schema"]}[Data],
						    FCT_STOCK_TRADES_Table = MARTS_Schema{[Name="FCT_STOCK_TRADES",Kind="Table"]}[Data],
						    #"Removed Other Columns" = Table.SelectColumns(FCT_STOCK_TRADES_Table,{"SYMBOL", "PRICE", "VOLUME", "TRADE_VALUE_USD", "TRADED_AT", "TRADED_HOUR", "TRADED_DATE", "DATE_KEY"})
						in
						    #"Removed Other Columns"

			annotation PBI_ResultType = Table

			annotation PBI_NavigationStepName = Navigation

		/// Calendar dimension table for date-based filtering and aggregation. Grain: one row per calendar day.
		table dim_date
			lineageTag: 4b305160-b680-4ca7-8174-bba6816e239e

			/// Integer date key in YYYYMMDD format. Primary key for joining to fact tables.
			column DATE_KEY
				dataType: double
				lineageTag: 000f9563-4000-4801-9ad1-b43628f726e8
				summarizeBy: none
				sourceColumn: DATE_KEY

				annotation SummarizationSetBy = Automatic

				annotation PBI_FormatHint = {"isGeneralNumber":true}

			/// Calendar date value. Use for date slicers and time intelligence.
			column DATE
				dataType: dateTime
				formatString: Short Date
				lineageTag: db6976b8-3804-4386-90fc-f92a1f423066
				summarizeBy: none
				sourceColumn: DATE

				annotation SummarizationSetBy = Automatic

				annotation UnderlyingDateTimeDataType = Date

			/// Four-digit year (e.g., 2026). Use for year-over-year comparisons.
			column YEAR
				dataType: int64
				lineageTag: d2108909-ef1e-4c25-b7b9-39ac63d1a36b
				summarizeBy: none
				sourceColumn: YEAR

				changedProperty = DataType

				annotation SummarizationSetBy = User

				annotation PBI_FormatHint = {"isGeneralNumber":true}

			/// Calendar quarter (1-4). Use for quarterly aggregations.
			column QUARTER
				dataType: double
				lineageTag: acaade56-3eef-4a21-acf5-df19431e439d
				summarizeBy: sum
				sourceColumn: QUARTER

				annotation SummarizationSetBy = Automatic

				annotation PBI_FormatHint = {"isGeneralNumber":true}

			/// Month number (1-12). Use for monthly aggregations.
			column MONTH
				dataType: double
				lineageTag: 68ff40c9-73e8-48e6-b5ae-9bfe1c72923a
				summarizeBy: sum
				sourceColumn: MONTH

				annotation SummarizationSetBy = Automatic

				annotation PBI_FormatHint = {"isGeneralNumber":true}

			/// Full month name (e.g., January, February). Use for display labels.
			column MONTH_NAME
				dataType: string
				lineageTag: f2079eaa-e2de-4100-9c32-b7338a399364
				summarizeBy: none
				sourceColumn: MONTH_NAME
				sortByColumn: MONTH

				changedProperty = SortByColumn

				annotation SummarizationSetBy = Automatic

			/// ISO week number (1-52/53). Use for weekly aggregations.
			column WEEK_OF_YEAR
				dataType: double
				lineageTag: 11cfebce-7716-45e0-ac16-4a625fb594c1
				summarizeBy: sum
				sourceColumn: WEEK_OF_YEAR

				annotation SummarizationSetBy = Automatic

				annotation PBI_FormatHint = {"isGeneralNumber":true}

			/// Day of month (1-31).
			column DAY_OF_MONTH
				dataType: double
				lineageTag: e7ecc57a-f17e-463b-8aea-2d905cb20d95
				summarizeBy: sum
				sourceColumn: DAY_OF_MONTH

				annotation SummarizationSetBy = Automatic

				annotation PBI_FormatHint = {"isGeneralNumber":true}

			/// Day of week number (0=Sunday, 6=Saturday).
			column DAY_OF_WEEK
				dataType: double
				lineageTag: 66e4afea-ac77-4dc8-bc6e-c5dc2c45a310
				summarizeBy: sum
				sourceColumn: DAY_OF_WEEK

				annotation SummarizationSetBy = Automatic

				annotation PBI_FormatHint = {"isGeneralNumber":true}

			/// Full day name (e.g., Monday, Tuesday). Use for day-of-week analysis.
			column DAY_NAME
				dataType: string
				lineageTag: 58dd9f2d-31a3-47a8-8ef5-5767e82eb16a
				summarizeBy: none
				sourceColumn: DAY_NAME

				annotation SummarizationSetBy = Automatic

			/// TRUE if Monday-Friday, FALSE if Saturday-Sunday.
			column IS_WEEKDAY
				dataType: boolean
				formatString: """TRUE"";""TRUE"";""FALSE"""
				lineageTag: 3ffad92e-bb07-4d57-806e-e9f363cd1dfe
				summarizeBy: none
				sourceColumn: IS_WEEKDAY

				annotation SummarizationSetBy = Automatic

			/// TRUE if US stock market is open (weekday, non-holiday).
			column IS_TRADING_DAY
				dataType: boolean
				formatString: """TRUE"";""TRUE"";""FALSE"""
				lineageTag: a9779dba-7e2f-44f6-9d7c-1ceca29b9027
				summarizeBy: none
				sourceColumn: IS_TRADING_DAY

				annotation SummarizationSetBy = Automatic

			column MONTH_YEAR
				dataType: string
				lineageTag: 2d525d06-b84c-487f-a1ea-98549972886e
				summarizeBy: none
				sourceColumn: MONTH_YEAR
				sortByColumn: MONTH

				changedProperty = SortByColumn

				annotation SummarizationSetBy = Automatic

			partition dim_date = m
				mode: import
				source =
						let
						    Source = Snowflake.Databases("JDGAEPV-LHA81787.snowflakecomputing.com","STOCK_ANALYTICS_WH",[Implementation="1.0"]),
						    STOCK_ANALYTICS_DB_Database = Source{[Name="STOCK_ANALYTICS_DB",Kind="Database"]}[Data],
						    MARTS_Schema = STOCK_ANALYTICS_DB_Database{[Name="MARTS",Kind="Schema"]}[Data],
						    DIM_COMPANIES_Table = MARTS_Schema{[Name="DIM_DATE",Kind="Table"]}[Data]
						in
						    DIM_COMPANIES_Table

			annotation PBI_NavigationStepName = Navigation

			annotation PBI_ResultType = Table

		/// Centralized measures table containing all DAX calculations for the Stock Analytics dashboard.
		table Metrics
			lineageTag: 9a1b2c3d-4e5f-6789-abcd-ef0123456789

			/// Counts all trade records in the filtered context.
			measure 'Total Trades' = COUNTROWS(fct_stock_trades)
				formatString: #,##0
				displayFolder: Base Calculations
				lineageTag: m001-base-total-trades

			/// Sums the share volume across all trades in the filtered context.
			measure 'Total Volume' = SUM(fct_stock_trades[VOLUME])
				formatString: #,##0
				displayFolder: Base Calculations
				lineageTag: m002-base-total-volume

			/// Sums the USD value (price x volume) of all trades in the filtered context.
			measure 'Total Trade Value' = SUM(fct_stock_trades[TRADE_VALUE_USD])
				formatString: $#,##0
				displayFolder: Base Calculations
				lineageTag: m003-base-total-trade-value

			/// Calculates the simple average trade price in the filtered context.
			measure 'Average Price' = AVERAGE(fct_stock_trades[PRICE])
				formatString: $#,##0.00
				displayFolder: Base Calculations
				lineageTag: m004-base-avg-price

			/// Counts the number of unique stock symbols in the filtered context.
			measure 'Distinct Stocks' = DISTINCTCOUNT(fct_stock_trades[SYMBOL])
				formatString: #,##0
				displayFolder: Base Calculations
				lineageTag: m005-base-distinct-stocks

			/// Counts the number of unique trading days in the filtered context.
			measure 'Trading Days' = DISTINCTCOUNT(fct_stock_trades[TRADED_DATE])
				formatString: #,##0
				displayFolder: Base Calculations
				lineageTag: m006-base-trading-days

			/// Counts the number of hourly OHLCV records in the filtered context.
			measure 'Hourly Periods' = COUNTROWS(fct_stock_ohlcv_hourly)
				formatString: #,##0
				displayFolder: Base Calculations
				lineageTag: m007-base-hourly-periods

			/// Averages the hourly price standard deviation. Higher values indicate greater price dispersion.
			measure 'Avg Volatility (StdDev)' = AVERAGE(fct_stock_ohlcv_hourly[STDDEV_PRICE])
				formatString: 0.0000
				displayFolder: Q1 - Volatility
				lineageTag: m101-vol-avg-stddev

			/// Returns the maximum hourly standard deviation. Identifies peak volatility periods.
			measure 'Max Volatility (StdDev)' = MAX(fct_stock_ohlcv_hourly[STDDEV_PRICE])
				formatString: 0.0000
				displayFolder: Q1 - Volatility
				lineageTag: m102-vol-max-stddev

			/// Averages the hourly high-low price range. Measures intraday price swing magnitude.
			measure 'Avg Price Range' = AVERAGE(fct_stock_ohlcv_hourly[PRICE_RANGE])
				formatString: $#,##0.00
				displayFolder: Q1 - Volatility
				lineageTag: m103-vol-avg-range

			/// Returns the maximum hourly high-low range. Identifies the widest price swings.
			measure 'Max Price Range' = MAX(fct_stock_ohlcv_hourly[PRICE_RANGE])
				formatString: $#,##0.00
				displayFolder: Q1 - Volatility
				lineageTag: m104-vol-max-range

			/// Calculates price range as a percentage of the open price. Normalizes volatility for comparison.
			measure 'Price Range %' = DIVIDE(AVERAGE(fct_stock_ohlcv_hourly[PRICE_RANGE]), AVERAGE(fct_stock_ohlcv_hourly[OPEN_PRICE]), 0)
				formatString: 0.00%
				displayFolder: Q1 - Volatility
				lineageTag: m106-vol-range-pct

			/// Averages the Volume-Weighted Average Price. Institutional fair value benchmark.
			measure 'Avg VWAP' = AVERAGE(fct_stock_ohlcv_hourly[VWAP])
				formatString: $#,##0.00
				displayFolder: Q2 - VWAP Analysis
				lineageTag: m201-vwap-avg

			/// Averages the hourly closing prices in the filtered context.
			measure 'Avg Close Price' = AVERAGE(fct_stock_ohlcv_hourly[CLOSE_PRICE])
				formatString: $#,##0.00
				displayFolder: Q2 - VWAP Analysis
				lineageTag: m202-vwap-avg-close

			/// Dollar difference between average close and VWAP. Positive = above fair value.
			measure 'VWAP Divergence $' = [Avg Close Price] - [Avg VWAP]
				formatString: $#,##0.00
				displayFolder: Q2 - VWAP Analysis
				lineageTag: m203-vwap-div-dollar

			/// Percentage divergence from VWAP. Values > 0.5% or < -0.5% indicate significant deviation.
			measure 'VWAP Divergence %' = DIVIDE([Avg Close Price] - [Avg VWAP], [Avg VWAP], 0)
				formatString: 0.00%
				displayFolder: Q2 - VWAP Analysis
				lineageTag: m204-vwap-div-pct

			/// Categorizes VWAP position: Above (buying pressure), Below (distribution), or Neutral.
			measure 'VWAP Signal' =
					VAR Divergence = [VWAP Divergence %]
					RETURN SWITCH(TRUE(), Divergence > 0.005, "Above VWAP (Buying Pressure)", Divergence < -0.005, "Below VWAP (Distribution)", "Near VWAP (Neutral)")
				displayFolder: Q2 - VWAP Analysis
				lineageTag: 21d7743c-ac0e-4a2e-87f0-b58c3008183e

			/// Counts hourly periods where close price exceeded VWAP. Indicates buying pressure.
			measure 'Hours Above VWAP' = CALCULATE(COUNTROWS(fct_stock_ohlcv_hourly), fct_stock_ohlcv_hourly[CLOSE_PRICE] > fct_stock_ohlcv_hourly[VWAP])
				formatString: #,##0
				displayFolder: Q2 - VWAP Analysis
				lineageTag: m206-vwap-hours-above

			/// Counts hourly periods where close price was below VWAP. Indicates selling pressure.
			measure 'Hours Below VWAP' = CALCULATE(COUNTROWS(fct_stock_ohlcv_hourly), fct_stock_ohlcv_hourly[CLOSE_PRICE] < fct_stock_ohlcv_hourly[VWAP])
				formatString: #,##0
				displayFolder: Q2 - VWAP Analysis
				lineageTag: m207-vwap-hours-below

			/// Percentage of hours trading above VWAP. Higher values suggest buying interest.
			measure 'VWAP Win Rate' = DIVIDE([Hours Above VWAP], [Hourly Periods], 0)
				formatString: 0.0%
				displayFolder: Q2 - VWAP Analysis
				lineageTag: m208-vwap-win-rate

			/// Averages the hourly percentage price change. Positive = upward momentum.
			measure 'Avg Price Change %' = AVERAGE(fct_stock_ohlcv_hourly[PCT_CHANGE])
				formatString: 0.00%
				displayFolder: Q3 - Momentum
				lineageTag: m301-mom-avg-pct-change

			/// Average price change during 9 AM hour (market open). Captures first-hour momentum.
			measure 'Market Open Momentum' = CALCULATE(AVERAGE(fct_stock_ohlcv_hourly[PCT_CHANGE]), HOUR(fct_stock_ohlcv_hourly[TRADED_HOUR]) = 9)
				formatString: 0.00%
				displayFolder: Q3 - Momentum
				lineageTag: m302-mom-market-open

			/// Counts hours with positive price change. Indicates bullish momentum persistence.
			measure 'Positive Momentum Hours' = CALCULATE(COUNTROWS(fct_stock_ohlcv_hourly), fct_stock_ohlcv_hourly[PCT_CHANGE] > 0)
				formatString: #,##0
				displayFolder: Q3 - Momentum
				lineageTag: m303-mom-positive-hours

			/// Counts hours with negative price change. Indicates bearish pressure persistence.
			measure 'Negative Momentum Hours' = CALCULATE(COUNTROWS(fct_stock_ohlcv_hourly), fct_stock_ohlcv_hourly[PCT_CHANGE] < 0)
				formatString: #,##0
				displayFolder: Q3 - Momentum
				lineageTag: m304-mom-negative-hours

			/// Percentage of hours with positive price change. Higher values indicate upward momentum.
			measure 'Momentum Win Rate' = DIVIDE([Positive Momentum Hours], [Hourly Periods], 0)
				formatString: 0.0%
				displayFolder: Q3 - Momentum
				lineageTag: m305-mom-win-rate

			/// Returns the largest single-hour percentage gain. Identifies peak bullish moves.
			measure 'Max Hourly Gain' = MAX(fct_stock_ohlcv_hourly[PCT_CHANGE])
				formatString: 0.00%
				displayFolder: Q3 - Momentum
				lineageTag: m306-mom-max-gain

			/// Returns the largest single-hour percentage loss. Identifies peak bearish moves.
			measure 'Max Hourly Loss' = MIN(fct_stock_ohlcv_hourly[PCT_CHANGE])
				formatString: 0.00%
				displayFolder: Q3 - Momentum
				lineageTag: m307-mom-max-loss

			/// Averages hourly trading volume. Baseline for identifying volume spikes.
			measure 'Avg Hourly Volume' = AVERAGE(fct_stock_ohlcv_hourly[TOTAL_VOLUME])
				formatString: #,##0
				displayFolder: Q4 - Volume Analysis
				lineageTag: m401-vol-avg-hourly

			/// Returns the maximum hourly volume. Identifies peak trading activity.
			measure 'Max Hourly Volume' = MAX(fct_stock_ohlcv_hourly[TOTAL_VOLUME])
				formatString: #,##0
				displayFolder: Q4 - Volume Analysis
				lineageTag: m402-vol-max-hourly

			/// Sums total volume across all hourly periods in the filtered context.
			measure 'Total Hourly Volume' = SUM(fct_stock_ohlcv_hourly[TOTAL_VOLUME])
				formatString: #,##0
				displayFolder: Q4 - Volume Analysis
				lineageTag: m403-vol-total-hourly

			/// Averages the number of trades per hour. Higher counts indicate active participation.
			measure 'Avg Trade Count' = AVERAGE(fct_stock_ohlcv_hourly[TRADE_COUNT])
				formatString: #,##0
				displayFolder: Q4 - Volume Analysis
				lineageTag: m404-vol-avg-trade-count

			/// Ratio of current volume to average volume. Values > 1.5 indicate volume spikes.
			measure 'Volume vs Avg Ratio' =
					VAR CurrentVolume = SUM(fct_stock_ohlcv_hourly[TOTAL_VOLUME])
					VAR AvgVolume = CALCULATE(AVERAGE(fct_stock_ohlcv_hourly[TOTAL_VOLUME]), ALLSELECTED(fct_stock_ohlcv_hourly[TRADED_DATE]), ALLSELECTED(fct_stock_ohlcv_hourly[TRADED_HOUR]))
					RETURN DIVIDE(CurrentVolume, AvgVolume, 0)
				formatString: 0.00
				displayFolder: Q4 - Volume Analysis
				lineageTag: c3516f0b-4937-4706-b0b2-f30eaae02789

			/// Flags periods where volume exceeds 1.5x the average as Spike, otherwise Normal.
			measure 'Volume Spike Flag' = IF([Volume vs Avg Ratio] > 1.5, "Spike", "Normal")
				displayFolder: Q4 - Volume Analysis
				lineageTag: m406-vol-spike-flag

			/// Average shares per trade. Higher values indicate institutional block trades.
			measure 'Avg Volume per Trade' = DIVIDE(SUM(fct_stock_ohlcv_hourly[TOTAL_VOLUME]), SUM(fct_stock_ohlcv_hourly[TRADE_COUNT]), 0)
				formatString: #,##0
				displayFolder: Q4 - Volume Analysis
				lineageTag: m407-vol-per-trade

			/// Calculates hourly return as (close - open) / open. Used for correlation analysis.
			measure 'Hourly Return' =
					VAR CurrentClose = AVERAGE(fct_stock_ohlcv_hourly[CLOSE_PRICE])
					VAR PriorClose = AVERAGE(fct_stock_ohlcv_hourly[OPEN_PRICE])
					RETURN DIVIDE(CurrentClose - PriorClose, PriorClose, 0)
				formatString: 0.00%
				displayFolder: Q5 - Correlation
				lineageTag: 13d6c624-6281-4bc3-bae9-36fb607421d4

			/// Calculates variance of hourly returns. Higher variance indicates less predictable movements.
			measure 'Return Variance' =
					VAR AvgReturn = [Avg Price Change %]
					RETURN AVERAGEX(fct_stock_ohlcv_hourly, POWER(fct_stock_ohlcv_hourly[PCT_CHANGE] - AvgReturn, 2))
				formatString: 0.0000
				displayFolder: Q5 - Correlation
				lineageTag: m502-corr-variance

			/// Standard deviation of hourly returns. Measures return dispersion.
			measure 'Return Std Dev' = SQRT([Return Variance])
				formatString: 0.00%
				displayFolder: Q5 - Correlation
				lineageTag: m503-corr-stddev

			/// Risk-adjusted return ratio (return / volatility). Higher values indicate better risk-reward.
			measure 'Sharpe-like Ratio' = DIVIDE([Avg Price Change %], [Return Std Dev], 0)
				formatString: 0.00
				displayFolder: Q5 - Correlation
				lineageTag: m504-corr-sharpe

			/// Averages hourly opening prices in the filtered context.
			measure 'Avg Open Price' = ```
					
					AVERAGE(fct_stock_ohlcv_hourly[OPEN_PRICE])
					    
					```
				formatString: $#,##0.00
				displayFolder: OHLCV Metrics
				lineageTag: m601-ohlcv-avg-open

			/// Averages hourly high prices in the filtered context.
			measure 'Avg High Price' = AVERAGE(fct_stock_ohlcv_hourly[HIGH_PRICE])
				formatString: $#,##0.00
				displayFolder: OHLCV Metrics
				lineageTag: m602-ohlcv-avg-high

			/// Averages hourly low prices in the filtered context.
			measure 'Avg Low Price' = AVERAGE(fct_stock_ohlcv_hourly[LOW_PRICE])
				formatString: $#,##0.00
				displayFolder: OHLCV Metrics
				lineageTag: m603-ohlcv-avg-low

			/// Returns the most recent closing price. Useful for current price cards.
			measure 'Latest Close Price' = CALCULATE(LASTNONBLANK(fct_stock_ohlcv_hourly[CLOSE_PRICE], 1), LASTNONBLANK(fct_stock_ohlcv_hourly[TRADED_DATE], 1))
				formatString: $#,##0.00
				displayFolder: OHLCV Metrics
				lineageTag: m604-ohlcv-latest-close

			measure Change = ```
					
					VAR __close = [Latest Close Price] 
					VAR __open = [Avg Open Price]
					VAR __change = __close - __open
					VAR __changePercent = DIVIDE(__change, __close)
					VAR __trendingUp = [SVG Trending Up]
					VAR __trendingDown = [SVG Trending Down]
					RETURN
					SWITCH(
					    TRUE(),
					    __change >= 0, __trendingUp & " " & FORMAT(__change, "+0.00") & " " & "(" & FORMAT(__changePercent, "+0.00%") & ")",
					    __change < 0, __trendingDown & " " & FORMAT(__change, "-0.00") & " " & "(" & FORMAT(__changePercent, "-0.00%") & ")"
					)
					
					```
				displayFolder: OHLCV Metrics
				lineageTag: f414d49f-2334-4240-a3eb-58bc164a93df
				dataCategory: ImageUrl

			measure 'SVG Trending Up' = ```
					
					"data:image/svg+xml;utf8,
					<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='none' stroke='%23aacc66' stroke-width='2' stroke-linecap='round' stroke-linejoin='round'>
					    <polyline points='22 7 13.5 15.5 8.5 10.5 2 17'></polyline>
					    <polyline points='16 7 22 7 22 13'></polyline>
					</svg>"
					
					```
				displayFolder: OHLCV Metrics
				lineageTag: a3227dde-f02f-46a8-8258-d99534293426
				dataCategory: ImageUrl

			measure 'SVG Trending Down' = ```
					
					"data:image/svg+xml;utf8,
					<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='none' stroke='%23FF6600' stroke-width='2' stroke-linecap='round' stroke-linejoin='round'>
					    <polyline points='22 17 13.5 8.5 8.5 13.5 2 7'></polyline>
					    <polyline points='16 17 22 17 22 11'></polyline>
					</svg>"
					
					```
				displayFolder: OHLCV Metrics
				lineageTag: 872afbf3-f961-420e-9a53-e418e158772c
				dataCategory: ImageUrl

			measure 'Change SVG' = ```
					
					VAR __close = [Latest Close Price] 
					VAR __open = [Avg Open Price]
					VAR __change = __close - __open
					VAR __changePercent = DIVIDE(__change, __open)
					
					// Formatting
					VAR __green = "#aacc66"
					VAR __red = "#FF6600"
					VAR __color = IF(__change >= 0, __green, __red)
					
					VAR __valText = FORMAT(__change, "+0.00;-0.00")
					VAR __pctText = "(" & FORMAT(__changePercent, "+0.0%;-0.0%") & ")"
					
					// THE FIX: We use a massive viewBox width (300) compared to height (36).
					// This forces the SVG to stretch horizontally within the cell.
					RETURN
					"data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 40'>
					    <g transform='translate(5, 5)' stroke='" & __color & "' stroke-width='2.5' fill='none'>
					        " & IF(__change >= 0, 
					            "<polyline points='18 7 11 14 7 10 2 15'></polyline><polyline points='13 7 18 7 18 12'></polyline>", 
					            "<polyline points='18 15 11 8 7 12 2 7'></polyline><polyline points='13 15 18 15 18 10'></polyline>"
					        ) & "
					    </g>
					    <text x='35' y='16' fill='" & __color & "' font-family='Segoe UI, Arial' font-size='18' font-weight='semi-bold'>" & __valText & "</text>
					    <text x='35' y='32' fill='" & __color & "' font-family='Segoe UI, Arial' font-size='14'>" & __pctText & "</text>
					</svg>"
					
					```
				displayFolder: OHLCV Metrics
				lineageTag: 89e0dc1b-bf2a-4ec9-897c-f35c32866e6b
				dataCategory: ImageUrl

			measure 'As of Date' = ```
					
					VAR _MaxFactDate =
					    CALCULATE(
					        MAX(fct_stock_ohlcv_hourly[TRADED_DATE])
					    )
					VAR _SelectedDate =
					    IF(
					        HASONEVALUE('Disconnected Date'[DATE]),
					        SELECTEDVALUE('Disconnected Date'[DATE])
					    )
					RETURN
					COALESCE(_SelectedDate, _MaxFactDate)
					
					```
				formatString: Short Date
				displayFolder: Dynamic Period Filter
				lineageTag: a21be7c0-e459-46dc-b9e5-c33b781ee871

			measure 'Period Interval (Days)' =
					
					VAR _Period = SELECTEDVALUE('Period Filter'[Period])
					RETURN
					SWITCH(
					    _Period,
					    "1D", 1,
					    "5D", 5,
					    "1M", 30,
					    "6M", 180,
					    "1Y", 365,
					    "5Y", 1825,
					    BLANK()   -- YTD and All fall here
					)
				formatString: 0
				displayFolder: Dynamic Period Filter
				lineageTag: a24efce7-79d0-4c6e-8a6a-04c2a615bdbf

			measure 'Dynamic Date Window' =
					
					VAR _AsOf = [As of Date]
					VAR _Interval = [Period Interval (Days)]
					VAR _Period = SELECTEDVALUE('Period Filter'[Period])
					
					VAR _EarliestSymbolDate =
					    CALCULATE(
					        MIN(fct_stock_ohlcv_hourly[TRADED_DATE]),
					        ALL(fct_stock_ohlcv_hourly),
					        VALUES(fct_stock_ohlcv_hourly[SYMBOL])
					    )
					
					RETURN
					SWITCH(
					    TRUE(),
					
					    NOT ISBLANK(_Interval),
					        CALCULATETABLE(
					            DATESINPERIOD(
					                fct_stock_ohlcv_hourly[TRADED_DATE],
					                _AsOf,
					                -_Interval,
					                DAY
					            )
					        ),
					
					    _Period = "YTD",
					        CALCULATETABLE(
					            DATESYTD(
					                fct_stock_ohlcv_hourly[TRADED_DATE],
					                "12/31"
					            )
					        ),
					
					    _Period = "All",
					        CALCULATETABLE(
					            DATESBETWEEN(
					                fct_stock_ohlcv_hourly[TRADED_DATE],
					                _EarliestSymbolDate,
					                _AsOf
					            )
					        ),
					
					    CALCULATETABLE(
					        FILTER(
					            VALUES(fct_stock_ohlcv_hourly[TRADED_DATE]),
					            FALSE()
					        )
					    )
					)
				formatString: Short Date
				displayFolder: Dynamic Period Filter
				lineageTag: 8e16be76-d317-456f-8170-8c3663cb0cc9

			measure 'Dates Range' =
					
					VAR __SelectedCalItem = SELECTEDVALUE('Period Window'[Period])
					
					VAR _MinDate =
					    CALCULATE(
					        MIN(fct_stock_ohlcv_hourly[TRADED_DATE])
					    )
					
					VAR _MaxDate =
					    CALCULATE(
					        MAX(fct_stock_ohlcv_hourly[TRADED_DATE])
					    )
					
					RETURN
					// SWITCH(
					//     TRUE(),
					//     __SelectedCalItem = "1D",
					        FORMAT(_MinDate, "MM-dd-yyyy") & " to " & FORMAT(_MaxDate, "MM-dd-yyyy")
					
					//     __SelectedCalItem = "5D",
