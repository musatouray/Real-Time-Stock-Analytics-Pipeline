table 'Period Filter'
	lineageTag: b56c1d0f-11ba-41c8-98e9-821ecb838d21

	calculationGroup

		calculationItem 1D = ```
				
				VAR __Interval = -1
				VAR __CutOff = [As of Date]
				
				RETURN
				CALCULATE(
				    SELECTEDMEASURE(),
				    DATESINPERIOD(
				        fct_stock_ohlcv_hourly[TRADED_DATE],
				        __Cutoff,
				        __Interval,
				        DAY
				    )
				)
				
				
				```

