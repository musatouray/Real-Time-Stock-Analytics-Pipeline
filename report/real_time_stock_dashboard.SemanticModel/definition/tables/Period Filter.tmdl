		calculationItem YTD = ```
				
				CALCULATE(
				    SELECTEDMEASURE(),
				    DATESYTD(
				        fct_stock_ohlcv_hourly[TRADED_DATE], 
				        "12/31"
				    )
				)
				
				
				```

		calculationItem 1Y =
				
				VAR __Interval = -365
				VAR __CutOff = [As of Date]
				
				RETURN
				CALCULATE(
				    SELECTEDMEASURE(),
				    DATESINPERIOD(
				        fct_stock_ohlcv_hourly[TRADED_DATE],
