				)

		calculationItem 5Y = ```
				
				VAR __Interval = -1825
				VAR __CutOff = [As of Date]
				
				RETURN
				CALCULATE(
				    SELECTEDMEASURE(),
				    DATESINPERIOD(
				        fct_stock_ohlcv_hourly[TRADED_DATE],
				        __Cutoff,
				        __Interval,
				        DAY
				    )
				)
				
				```

		calculationItem All = ```
				
				VAR __Cutoff = [As of Date]
				
				VAR __EarliestSymbolDate =
				    CALCULATE(
				        MIN(fct_stock_ohlcv_hourly[TRADED_DATE]),
				        ALL(fct_stock_ohlcv_hourly),
				        VALUES(fct_stock_ohlcv_hourly[SYMBOL])
				    )
				
				RETURN
				CALCULATE(
				    SELECTEDMEASURE(),
				    DATESBETWEEN(
				        fct_stock_ohlcv_hourly[TRADED_DATE], 
				        __EarliestSymbolDate,
				        __Cutoff
				    )
				)
				
				```

